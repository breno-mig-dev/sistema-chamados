{% extends 'base.html.twig' %}

{% block title %}Usuários - Admin{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Gestão de Usuários</h1>
        <a href="{{ path('admin_user_new') }}" class="btn btn-primary">
            <i class="bi bi-person-plus"></i> Novo Usuário
        </a>
    </div>

    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Nome</th>
                            <th>E-mail</th>
                            <th>Nível de Acesso</th>
                            <th class="text-end">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for user in users %}
                        <tr>
                            <td>{{ user.id }}</td>
                            <td>{{ user.name }}</td>
                            <td>{{ user.email }}</td>
                            <td>
                                {% for role in user.roles %}
                                    {% if role == 'ROLE_ADMIN' %}
                                        <span class="badge text-bg-danger">Admin</span>
                                    {% elseif role == 'ROLE_TECHNICIAN' %}
                                        <span class="badge text-bg-warning">Técnico</span>
                                    {% elseif role == 'ROLE_USER' %}
                                        <span class="badge text-bg-info">Usuário</span>
                                    {% endif %}
                                {% endfor %}
                            </td>
                            <td class="text-end">
                                <a href="{{ path('admin_user_edit', {id: user.id}) }}" class="btn btn-sm btn-outline-secondary">Editar</a>
                                {% if app.user != user %}
                                <form action="{{ path('admin_user_delete', {id: user.id}) }}" method="post" class="d-inline" onsubmit="return confirm('Tem certeza que deseja excluir este usuário?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete_' ~ user.id) }}">
                                    <button class="btn btn-sm btn-outline-danger">Excluir</button>
                                </form>
                                {% endif %}
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="5" class="text-center text-muted">Nenhum usuário encontrado.</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}
