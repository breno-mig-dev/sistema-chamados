{% extends "base.html.twig" %}

{% block title %}{{ title }} - HelpDesk{% endblock %}

{% block content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0"><i class="bi bi-list-check"></i> {{ title }}</h1>
    <a href="{{ path('ticket_new') }}" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Novo Chamado
    </a>
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>#</th>
                    <th>Título</th>
                    <th>Categoria</th>
                    <th>Prioridade</th>
                    <th>Status</th>
                    <th>Solicitante</th>
                    <th>Atualizado</th>
                    <th class="text-end">Ações</th>
                </tr>
            </thead>
            <tbody>
                {% for ticket in tickets %}
                    <tr>
                        <td>{{ ticket.id }}</td>
                        <td>
                            <a href="{{ path('ticket_show', { id: ticket.id }) }}" class="text-decoration-none fw-semibold">
                                {{ ticket.title }}
                            </a>
                        </td>
                        <td>{{ ticket.category.name }}</td>
                        <td><span class="badge text-bg-{{ ticket.priority.badge }}">{{ ticket.priority.label }}</span></td>
                        <td><span class="badge text-bg-{{ ticket.status.badge }}">{{ ticket.status.label }}</span></td>
                        <td>{{ ticket.requester.name }}</td>
                        <td>{{ ticket.updatedAt|date('d/m/Y H:i') }}</td>
                        <td class="text-end">
                            <a href="{{ path('ticket_show', { id: ticket.id }) }}" class="btn btn-sm btn-outline-primary">Ver</a>
                            {% if is_granted('edit', ticket) %}
                                <a href="{{ path('ticket_edit', { id: ticket.id }) }}" class="btn btn-sm btn-outline-secondary">Editar</a>
                            {% endif %}
                            {% if is_granted('delete', ticket) %}
                                <form method="post" action="{{ path('ticket_delete', { id: ticket.id }) }}" class="d-inline" onsubmit="return confirm('Remover este chamado?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete_' ~ ticket.id) }}">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Remover</button>
                                </form>
                            {% endif %}
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="8" class="text-center py-5 text-muted">
                            Nenhum chamado encontrado.
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
