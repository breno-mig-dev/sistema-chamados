{% extends "base.html.twig" %}

{% block title %}Dashboard - HelpDesk{% endblock %}

{% block content %}
<div class="row">
    <div class="col-12">
        <h1 class="mb-4"><i class="bi bi-house"></i> Dashboard</h1>
    </div>
</div>

<div class="row">
    <div class="col-md-6 col-lg-3 mb-4">
        <div class="card text-center">
            <div class="card-body">
                <i class="bi bi-ticket2 text-primary" style="font-size: 2rem;"></i>
                <h5 class="card-title mt-2">Chamados Abertos</h5>
                <p class="card-text display-6">0</p>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-lg-3 mb-4">
        <div class="card text-center">
            <div class="card-body">
                <i class="bi bi-hourglass-split text-warning" style="font-size: 2rem;"></i>
                <h5 class="card-title mt-2">Em Atendimento</h5>
                <p class="card-text display-6">0</p>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-lg-3 mb-4">
        <div class="card text-center">
            <div class="card-body">
                <i class="bi bi-check-circle text-success" style="font-size: 2rem;"></i>
                <h5 class="card-title mt-2">Resolvidos</h5>
                <p class="card-text display-6">0</p>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-lg-3 mb-4">
        <div class="card text-center">
            <div class="card-body">
                <i class="bi bi-archive text-secondary" style="font-size: 2rem;"></i>
                <h5 class="card-title mt-2">Fechados</h5>
                <p class="card-text display-6">0</p>
            </div>
        </div>
    </div>
</div>

<div class="row mt-4">
    <div class="col-12">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="bi bi-list"></i> Bem-vindo ao HelpDesk!</h5>
            </div>
            <div class="card-body">
                <p>Sistema de gerenciamento de chamados técnicos com controle de acesso por perfil.</p>
                <p class="mb-0"><strong>Seu perfil:</strong> 
                    {% if 'ROLE_ADMIN' in app.user.roles %}
                        Administrador
                    {% elseif 'ROLE_TECHNICIAN' in app.user.roles %}
                        Técnico
                    {% else %}
                        Usuário
                    {% endif %}
                </p>
            </div>
        </div>
    </div>
</div>
{% endblock %}
