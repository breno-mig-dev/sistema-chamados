{# templates/email/ticket_status_changed.html.twig #}
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <title>Atualização de Chamado</title>
    <style>
        body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; }
        .container { max-width: 600px; margin: 0 auto; padding: 20px; border: 1px solid #ddd; border-radius: 5px; }
        .header { background-color: #f8f9fa; padding: 10px; text-align: center; border-bottom: 1px solid #ddd; }
        .content { padding: 20px 0; }
        .footer { text-align: center; font-size: 12px; color: #777; border-top: 1px solid #ddd; padding-top: 10px; }
        .btn { display: inline-block; padding: 10px 15px; background-color: #0d6efd; color: #fff; text-decoration: none; border-radius: 4px; }
        .status { font-weight: bold; color: #0d6efd; }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h2>Atualização no seu chamado #{{ ticket.id }}</h2>
        </div>
        <div class="content">
            <p>Olá, <strong>{{ ticket.requester.name }}</strong>!</p>
            <p>
                O status do seu chamado <strong>"{{ ticket.title }}"</strong>
                foi atualizado para: <span class="status">{{ ticket.status.label() }}</span>.
            </p>
            <p style="text-align: center; margin-top: 30px;">
                <a href="{{ url('ticket_show', {id: ticket.id}) }}" class="btn">Ver chamado</a>
            </p>
        </div>
        <div class="footer">
            Este é um e-mail automático do sistema de chamados (HelpDesk). Por favor, não responda.
        </div>
    </div>
</body>
</html>
